# CoreIntent / Zynthio Environment Configuration
# Copy to .env and fill in your keys

# AI Services
ANTHROPIC_API_KEY=sk-ant-xxx
GROK_API_KEY=xai-xxx
PERPLEXITY_API_KEY=pplx-xxx

# Exchange APIs
BINANCE_API_KEY=
BINANCE_SECRET=
COINBASE_API_KEY=
COINBASE_SECRET=
GTRADE_WALLET_KEY=

# Trading Config
TRADING_MODE=paper          # paper | live
RISK_LEVEL=medium           # low | medium | high
MAX_POSITION_PCT=10
STOP_LOSS_PCT=5
TAKE_PROFIT_PCT=15
CIRCUIT_BREAKER_PCT=0.8

# Infrastructure
NEXT_PUBLIC_APP_URL=http://localhost:3000
VERCEL_URL=
DATABASE_URL=
REDIS_URL=
