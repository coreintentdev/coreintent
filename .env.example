# CoreIntent / Zynthio Environment Configuration
# Copy to .env and fill in your keys

# ═══════════════════════════════════════════
# AI SERVICES (The Orchestra)
# ═══════════════════════════════════════════

# Anthropic — Claude (Post-trade analysis, risk, agents)
ANTHROPIC_API_KEY=sk-ant-xxx

# X.ai — Grok Plus/Pro (Signal detection, market sentiment)
GROK_API_KEY=xai-xxx
GROK_TIER=pro                # plus | pro

# Perplexity Max — (Research, coordination, 9 connectors)
PERPLEXITY_API_KEY=pplx-xxx
PERPLEXITY_TIER=max          # pro | max

# Google — Gemini (supplemental analysis)
GOOGLE_AI_KEY=

# ═══════════════════════════════════════════
# X / TWITTER (Premium+ API access)
# ═══════════════════════════════════════════
X_BEARER_TOKEN=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
X_ACCOUNT=@coreintentai
X_TIER=premium_plus          # basic | pro | premium_plus

# ═══════════════════════════════════════════
# EXCHANGE APIs
# ═══════════════════════════════════════════

# Binance
BINANCE_API_KEY=
BINANCE_SECRET=

# Coinbase
COINBASE_API_KEY=
COINBASE_SECRET=

# gTrade (DeFi)
GTRADE_WALLET_KEY=
GTRADE_CHAIN=polygon         # polygon | arbitrum

# ═══════════════════════════════════════════
# INFRASTRUCTURE
# ═══════════════════════════════════════════

# Cloudflare Pro
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=
CF_PLAN=pro                  # free | pro | business

# Vercel
NEXT_PUBLIC_APP_URL=http://localhost:3000
VERCEL_URL=
VERCEL_TOKEN=

# Cloudzy VPS (trading engine backend)
VPS_HOST=<your-vps-ip>
VPS_USER=<your-vps-user>
VPS_SSH_KEY=

# Database / Cache
DATABASE_URL=
REDIS_URL=

# ═══════════════════════════════════════════
# CONNECTED PLATFORMS (Perplexity Connectors)
# ═══════════════════════════════════════════
GMAIL_CONNECTED=true
GOOGLE_DRIVE_CONNECTED=true
LINEAR_API_KEY=
NOTION_API_KEY=
GITHUB_TOKEN=
ASANA_TOKEN=
SLACK_WEBHOOK=
JIRA_TOKEN=
CONFLUENCE_TOKEN=

# ═══════════════════════════════════════════
# TRADING CONFIG
# ═══════════════════════════════════════════
TRADING_MODE=paper            # paper | live
RISK_LEVEL=medium             # low | medium | high
MAX_POSITION_PCT=10
STOP_LOSS_PCT=5
TAKE_PROFIT_PCT=15
CIRCUIT_BREAKER_PCT=0.8
REBALANCE_SCHEDULE=0 0 * * * # Daily @ 00:00 UTC
AI_MIN_CONFIDENCE=0.75
