# CoreIntent / Zynthio Environment Configuration
# Copy to .env and fill in your keys

# ═══════════════════════════════════════════
# AI SERVICES (The Orchestra — 4 models)
# ═══════════════════════════════════════════

# Anthropic — Claude (Deep analysis, risk, agents)
ANTHROPIC_API_KEY=sk-ant-xxx

# X.ai — Grok (Signal detection, market sentiment, content)
GROK_API_KEY=xai-xxx
GROK_TIER=pro                # plus | pro

# Perplexity — Research, fact-checking
PERPLEXITY_API_KEY=pplx-xxx
PERPLEXITY_TIER=free         # free | pro | max

# Google — Gemini 2.0 Flash (Code gen, scanning, grounding)
GEMINI_API_KEY=
# Additional Gemini keys for fallback/rotation:
# GEMINI_API_KEY_2=
# GEMINI_API_KEY_3=
# GEMINI_API_KEY_4=

# ═══════════════════════════════════════════
# GOOGLE CLOUD PLATFORM (113+ APIs enabled)
# ═══════════════════════════════════════════
GCP_PROJECT_ID=
GCP_SA_KEY=                  # Service account JSON (for GitHub Actions)
GCP_SA_EMAIL=                # e.g. 282300124652-compute@developer.gserviceaccount.com
GCP_REGION=europe-west1

# Google OAuth (Video Pipeline)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Google Drive (for rclone / 4-Way Deploy)
GOOGLE_DRIVE_FOLDER_ID=

# Google Cloud Build
CLOUDBUILD_MACHINE_TYPE=E2_HIGHCPU_32

# Google Voice API
GOOGLE_VOICE_API_KEY=

# ═══════════════════════════════════════════
# X / TWITTER (Premium+ API access)
# ═══════════════════════════════════════════
X_BEARER_TOKEN=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
X_ACCOUNT=@coreintentai
X_TIER=premium_plus          # basic | pro | premium_plus

# ═══════════════════════════════════════════
# EXCHANGE APIs (PLANNED — not connected)
# ═══════════════════════════════════════════

# Binance
BINANCE_API_KEY=
BINANCE_SECRET=

# Coinbase
COINBASE_API_KEY=
COINBASE_SECRET=

# gTrade (DeFi)
GTRADE_WALLET_KEY=
GTRADE_CHAIN=polygon         # polygon | arbitrum

# ═══════════════════════════════════════════
# VPS INFRASTRUCTURE (v3.0 — 3 nodes)
# ═══════════════════════════════════════════

# The Mansion (legacy — Cloudzy)
VPS_MANSION_HOST=104.194.156.109
VPS_MANSION_ROLE=nginx-proxy

# Deployment Alpha (Contabo)
VPS_ALPHA_HOST=161.97.89.49
VPS_ALPHA_ROLE=deploy-target

# Execution Beta (Contabo)
VPS_BETA_HOST=84.247.137.105
VPS_BETA_ROLE=heavy-compute

# Tailscale mesh
TAILSCALE_IP=100.122.99.34
VPS_SSH_KEY=/root/.ssh/zynthio_deploy

# ═══════════════════════════════════════════
# CLOUDFLARE
# ═══════════════════════════════════════════
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=
CF_PLAN=pro                  # free | pro | business

# ═══════════════════════════════════════════
# DEPLOY & HOSTING
# ═══════════════════════════════════════════
NEXT_PUBLIC_APP_URL=http://localhost:3000
VERCEL_URL=
VERCEL_TOKEN=

# Database / Cache (planned)
DATABASE_URL=
REDIS_URL=

# ═══════════════════════════════════════════
# CONNECTED PLATFORMS
# ═══════════════════════════════════════════
GMAIL_CONNECTED=true
GOOGLE_DRIVE_CONNECTED=true
LINEAR_API_KEY=
NOTION_API_KEY=
NOTION_HUB_ID=               # 32a7af4071d081d8a9e2c59138481ab8
GITHUB_TOKEN=
ASANA_TOKEN=
SLACK_WEBHOOK=
JIRA_TOKEN=
CONFLUENCE_TOKEN=

# ═══════════════════════════════════════════
# CONTENT & CREATIVE
# ═══════════════════════════════════════════
HEYGEN_API_KEY=              # Pro — check if still active
DISTROKID_ACCOUNT=           # 23 tracks unreleased
SUNO_TRACKS_COUNT=239        # Confirmed count

# ═══════════════════════════════════════════
# TRADING CONFIG
# ═══════════════════════════════════════════
TRADING_MODE=paper            # paper | live
RISK_LEVEL=medium             # low | medium | high
MAX_POSITION_PCT=10
STOP_LOSS_PCT=5
TAKE_PROFIT_PCT=15
CIRCUIT_BREAKER_PCT=0.8
REBALANCE_SCHEDULE=0 0 * * * # Daily @ 00:00 UTC
AI_MIN_CONFIDENCE=0.75
